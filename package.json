{
  "name": "kickoff",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "start": "node .output/server/index.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "db:seed": "node --env-file=.env --import=tsx/esm scripts/seed-matches.ts",
    "db:seed:dev": "node --env-file=.env --import=tsx/esm scripts/seed-dev.ts",
    "db:migrate:competitions": "node --env-file=.env --import=tsx/esm scripts/migrate-to-competitions.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.80",
    "@ai-sdk/openai": "^3.0.67",
    "@neondatabase/serverless": "^0.10.4",
    "@tanstack/react-query": "^5.64.2",
    "@tanstack/react-router": "^1.114.23",
    "@tanstack/react-start": "^1.114.23",
    "ai": "^6.0.193",
    "better-auth": "^1.2.7",
    "drizzle-orm": "^0.45.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vinxi": "^0.5.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
