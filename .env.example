DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
BETTER_AUTH_SECRET=your-secret-here-min-32-chars
BETTER_AUTH_URL=http://localhost:3000
# AI provider (google or openai — default: google)
AI_PROVIDER=google
AI_MODEL=gemini-2.0-flash
GOOGLE_GENERATIVE_AI_API_KEY=your-google-ai-api-key  # https://aistudio.google.com/apikey

# Required only if AI_PROVIDER=openai
OPENAI_API_KEY=your-openai-api-key
CRON_SECRET=your-cron-secret-min-32-chars
API_FOOTBALL_KEY=your-api-football-key  # https://api-sports.io (free: 100 req/day)

# Comma-separated user IDs with admin access to /admin (leave blank initially; fill in after first login)
ADMIN_USER_IDS=

# OAuth providers (optional — omit to disable)
GITHUB_CLIENT_ID=your-github-oauth-app-client-id
GITHUB_CLIENT_SECRET=your-github-oauth-app-client-secret
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
